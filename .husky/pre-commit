#!/bin/sh
# ──────────────────────────────────────────────────────────────────────────────
# pre-commit hook: 提交前快速校验（对齐 CI，但跳过耗时步骤）
# ──────────────────────────────────────────────────────────────────────────────

cd "$(git rev-parse --show-toplevel)" || exit 1

# Debug: check if GIT_INDEX_FILE is set
echo "debug: GIT_INDEX_FILE=${GIT_INDEX_FILE:-<not set>}" >&2

# ── 1. 增量 auto-fix ──
npm run lint:staged

# ── 2. 格式校验 ──
echo "🔍 pre-commit: format:check..."
npm run format:check
if [ $? -ne 0 ]; then
  echo "❌ Formatting issues found. Run 'npm run format' to fix."
  exit 1
fi

# ── 3. 单元测试（清除 GIT_INDEX_FILE 避免干扰 git 操作）──
echo "🔍 pre-commit: vitest..."
unset GIT_INDEX_FILE
npm test
if [ $? -ne 0 ]; then
  echo "❌ Unit tests failed. Fix before committing."
  exit 1
fi

exit 0
