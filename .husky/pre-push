#!/bin/sh
# ──────────────────────────────────────────────────────────────────────────────
# pre-push hook: 推送前类型检查 + 单元测试 + 变更模块的 e2e 测试
# ──────────────────────────────────────────────────────────────────────────────
# 策略：与 CI 对齐但降权耗时步骤。
#   ✅ typecheck  — 有 .ts 变更时运行（CI 阻塞，此处也阻塞）
#   ✅ test       — Vitest 单元测试（CI 阻塞，此处也阻塞）
#   ✅ e2e 测试   — 仅变更模块（CI 阻塞，此处 blocking exit 1）
#   ❌ format:check — pre-commit 已跑，不重复
#   ❌ semgrep     — 太慢，仅 CI 跑
#
# 通过 git diff --name-only 检测本次推送变更的模块，仅运行受影响模块的测试。
# 如果变更覆盖多个模块，最坏情况跑全量测试（耗时可能较长）。

# 切换到 git 根目录，确保相对路径在任何工作目录下都正确
cd "$(git rev-parse --show-toplevel)" || exit 0

# 只在有变更文件时运行（跳过空推送、标签推送等）
# 使用 @{push}..HEAD 对比远程跟踪分支，支持多次提交后推送的场景
# 首次推送或无远程跟踪分支时静默跳过
CHANGED_FILES=$(git diff --name-only "@{push}..HEAD" 2>/dev/null || echo "")

if [ -z "$CHANGED_FILES" ]; then
  exit 0
fi

# ── 类型检查（当有 .ts/.tsx 变更时）──
echo "$CHANGED_FILES" | grep -q '\.tsx\?$'
if [ $? -eq 0 ]; then
	echo "🔍 pre-push: typecheck..."
  npm run typecheck
  if [ $? -ne 0 ]; then
    echo "❌ TypeScript errors found. Fix before pushing."
    exit 1
  fi
fi

# ── 单元测试（对齐 CI unit-tests job）──
echo "🔍 pre-push: vitest..."
npm test
if [ $? -ne 0 ]; then
  echo "❌ Unit tests failed. Fix before pushing."
  exit 1
fi

# 提取变更的扩展名和技能名
EXTS=""
SKILLS=""
for file in $CHANGED_FILES; do
  case "$file" in
    # 目录扩展优先匹配：extensions/category/name/index.ts → name
    # 必须在单文件匹配之前，避免 index.ts 被 *.ts 模式误匹配
    extensions/*/index.ts)
      name=$(basename "$(dirname "$file")")
      EXTS="$EXTS $name"
      ;;
    # 单文件扩展：extensions/category/name.ts → name
    # ⚠ bash case 中 * 会匹配斜杠，必须排除深层嵌套文件
    # 如 extensions/cat/name/sub.ts 应跳过（属于目录扩展的内部文件）
    extensions/*/*.ts)
      rel="${file#extensions/}"
      case "$rel" in
        */*/*) ;;  # 超过1层目录 → 跳过
        *)
          name=$(basename "$file" .ts)
          EXTS="$EXTS $name"
          ;;
      esac
      ;;
    # 技能在分类子目录中：skills/category/name/SKILL.md
    skills/*/*/SKILL.md)
      name=$(basename "$(dirname "$file")")
      SKILLS="$SKILLS $name"
      ;;
    skills/*/SKILL.md)
      name=$(basename "$(dirname "$file")")
      SKILLS="$SKILLS $name"
      ;;
  esac
done

# 去重
EXTS=$(echo "$EXTS" | tr ' ' '\n' | sort -u | tr '\n' ' ')
SKILLS=$(echo "$SKILLS" | tr ' ' '\n' | sort -u | tr '\n' ' ')

if [ -z "$EXTS" ] && [ -z "$SKILLS" ]; then
  # 没有变更涉及的扩展/技能，跳过
  exit 0
fi

echo "🔍 pre-push: e2e tests for changed modules..."
echo "   Extensions:${EXTS:- (none)}"
echo "   Skills:${SKILLS:- (none)}"

# 逐模块运行测试（不阻塞推送，失败只 warning）
ALL_PASS=true

for ext in $EXTS; do
  echo "   → Testing extension: $ext"
  CI=true bash test/scripts/run-e2e.sh --ext "$ext" >/dev/null 2>&1
  if [ $? -eq 0 ] || [ $? -eq 124 ]; then
    echo "      ✅ $ext passed"
  else
    echo "      ⚠️  $ext has review-required or failed cases"
    ALL_PASS=false
  fi
done

for skill in $SKILLS; do
  echo "   → Testing skill: $skill"
  CI=true bash test/scripts/run-e2e.sh --skill "$skill" >/dev/null 2>&1
  if [ $? -eq 0 ] || [ $? -eq 124 ]; then
    echo "      ✅ $skill passed"
  else
    echo "      ⚠️  $skill has review-required or failed cases"
    ALL_PASS=false
  fi
done

if [ "$ALL_PASS" = false ]; then
  echo "⚠️  Some e2e tests flagged review-required or had failures."
  echo "   Check test/results/$(ls -1t test/results/ | head -1)/ for details."
  exit 1
fi

exit 0
